# ── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/pikishield
# OR for Atlas: mongodb+srv://user:pass@cluster.mongodb.net/pikishield

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string_min_32_chars
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Frontend URL (for CORS) ───────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── File Uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ── M-Pesa (Safaricom Daraja — fill in for production) ───────────────────────
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_PASSKEY=your_lipa_na_mpesa_passkey
MPESA_SHORTCODE=174379
MPESA_CALLBACK_URL=https://your-domain.com/api/payments/mpesa/callback
MPESA_ENV=sandbox

# ── SMS (Africa's Talking — fill in for production) ──────────────────────────
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=sandbox
AT_SENDER_ID=PikiShield
